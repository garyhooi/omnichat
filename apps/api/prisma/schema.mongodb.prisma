// =============================================================================
// OmniChat — Prisma Schema (MongoDB variant)
// =============================================================================
// Activated by: scripts/use-provider.sh mongodb
// Key differences from SQL variants:
//   - provider = "mongodb"
//   - All @id fields use @map("_id") to align with MongoDB's native _id field
//   - No @@index directives needed for _id (MongoDB indexes _id automatically)
//   - No @db.Text — MongoDB stores strings without length limits natively
//   - No onDelete: Cascade — MongoDB doesn't enforce referential integrity;
//     cascade deletion must be handled in application code (ChatService)
//   - Relations are purely "virtual" (Prisma-level only) — no foreign key
//     constraints exist in MongoDB
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Conversation {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  visitorId String
  status    String   @default("active")
  agentId          String?  @db.ObjectId
  metadata         String?
  visitorIp        String?
  visitorBrowser   String?
  visitorOs        String?
  visitorDevice    String?
  visitorCurrentUrl String?
  visitorTimezone   String?
  visitorLanguage   String?
  visitorScreenRes  String?
  visitorReferrer   String?
  rating           Int?
  review           String?
  agentRemarks     String?
  assignedUsername String?
  specialistUsername String?
  resolvedByUsername String?
  createdAt        DateTime @default(now())
  updatedAt DateTime @updatedAt

  agent    AdminUser? @relation(fields: [agentId], references: [id])
  messages Message[]

  @@index([status, updatedAt])
  @@index([agentId])
  @@index([visitorId])
  @@index([updatedAt])
}

model Message {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  conversationId String   @db.ObjectId
  senderType     String
  senderId       String?
  messageType    String   @default("text")
  content        String?
  attachmentUrl  String?
  attachmentThumbnailUrl String?
  readAt         DateTime?
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id])

  @@index([conversationId])
  @@index([createdAt])
}
enum AdminRole {
  agent
  admin
  developer
}

model AdminUser {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  username     String   @unique
  passwordHash String
  displayName  String
  role         AdminRole @default(agent)
  isOnline     Boolean  @default(false)
  isLocked     Boolean  @default(false)
  registrationIp String?
  lastLoginIp    String?
  userAgent      String?
  lastSeenAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  conversations Conversation[]
  sessions      Session[]
  refreshTokens RefreshToken[]

  @@index([isOnline, lastSeenAt])
  @@index([isLocked, isOnline])
}

model Session {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  jti         String   @unique
  adminUserId String   @db.ObjectId
  expiresAt   DateTime
  revoked     Boolean  @default(false)
  createdAt   DateTime @default(now())

  admin       AdminUser @relation(fields: [adminUserId], references: [id])

  @@index([adminUserId])
}

model RefreshToken {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  tokenHash   String   @unique
  adminUserId String   @db.ObjectId
  expiresAt   DateTime
  revoked     Boolean  @default(false)
  createdAt   DateTime @default(now())

  admin       AdminUser @relation(fields: [adminUserId], references: [id])

  @@index([adminUserId])
}

model SiteConfig {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  siteName           String   @unique
  bubbleColor        String   @default("#4F46E5")
  welcomeMessage     String   @default("Hello! How can we help you today?")
  offlineMessage     String   @default("We are currently offline. Please check back later.")
  greetingMessage    String?
  bubbleSize         String   @default("medium")
  bubblePattern      String   @default("solid")
  websitePosition    String   @default("bottom-right")
  bubbleIcon         String   @default("💬")
  allowedOrigins     String
  adminAllowedIps    String?
  isActive           Boolean  @default(true)
  isOfflineMode      Boolean  @default(false)
  enableReadReceipts Boolean  @default(true)
  notificationSoundUrl String?
  showAdminWidget   Boolean  @default(true)
  showVisitorWidget Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([isActive])
}

model QuickReply {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  title     String
  content   String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([createdAt])
}

model UploadToken {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  token          String   @unique
  conversationId String   @db.ObjectId
  expiresAt      DateTime
  used           Boolean  @default(false)
  createdAt      DateTime @default(now())

  @@index([conversationId])
  @@index([expiresAt])
}

// =============================================================================
// AI Agent Models
// =============================================================================

model AiProvider {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  name           String   @unique
  providerType   String   // openai, anthropic, openrouter, ollama, deepseek, gemini, grok
  apiKey         String?  // encrypted; null for ollama
  baseUrl        String?  // custom endpoint (required for ollama/openrouter)
  chatModelId    String   // e.g. "gpt-4o", "claude-sonnet-4-20250514"
  embeddingModelId String? // e.g. "text-embedding-3-small"; null = use chat provider default
  isActive       Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([createdAt])
}

model AiAgentConfig {
  id                     String   @id @default(auto()) @map("_id") @db.ObjectId
  enabled                Boolean  @default(false)
  systemPrompt           String   @default("You are a helpful customer support assistant. Be concise and helpful.")
  greetingMessage        String?  // sent when AI starts handling a conversation
  humanRequestKeywords   String?  // comma-separated list of phrases that trigger human handoff
  maxTokensPerResponse   Int      @default(1024)
  temperature            Float    @default(0.7)
  maxTurnsPerConversation Int     @default(50)
  maxTokensPerSession    Int      @default(50000)
  ragFailureThreshold    Int      @default(2)    // consecutive RAG zero-results before handoff
  humanRequestThreshold  Int      @default(2)    // times visitor asks for human before handoff
  aiRateLimitPerMinute   Int      @default(10)
  spamIpBlacklistMinutes Int      @default(15)
  embeddingProviderId    String?  // ID of the provider to use for embeddings (null = use active chat provider)
  translateProviderId    String?  // ID of the provider to use for translation (null = use active chat provider)
  translationEnabled     Boolean  @default(true) // toggle translation feature on/off globally
  autoTranslationEnabled Boolean  @default(true) // auto-translate incoming messages
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model KnowledgeDocument {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  title           String
  fileName        String
  fileType        String   // txt, md, pdf, docx, csv
  fileSize        Int
  content         String   // raw extracted text
  embeddingStatus String   @default("pending") // pending, processing, completed, failed
  errorMessage    String?
  chunkCount      Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  chunks DocumentChunk[]

  @@index([createdAt])
}

model DocumentChunk {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  documentId String   @db.ObjectId
  content    String
  embedding  Float[]  // vector stored as array of floats (MongoDB Atlas Vector Search)
  chunkIndex Int
  metadata   String?  // JSON metadata
  createdAt  DateTime @default(now())

  document KnowledgeDocument @relation(fields: [documentId], references: [id])

  @@index([documentId])
}

model AiConversationState {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  conversationId     String   @unique
  failureCount       Int      @default(0)
  ragFailureCount    Int      @default(0)
  humanRequestCount  Int      @default(0)
  tokensUsed         Int      @default(0)
  turnCount          Int      @default(0)
  handoffTriggered   Boolean  @default(false)
  handoffReason      String?
  isAiHandling       Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model ToolRegistration {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  name               String   @unique
  description        String
  parametersSchema   String   // JSON Schema for tool parameters
  handlerType        String   @default("builtin") // builtin, external
  endpoint           String?  // HTTP endpoint for external tools
  authType           String?  // "none" | "static" | "token-exchange"
  authConfig         String?  // JSON — { tokenUrl } for token-exchange; { token } for static
  isActive           Boolean  @default(true)
  requiredPermission String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([createdAt])
  @@index([isActive, handlerType])
}

// AI Logs (stores AI provider failures and important events)
model AiLog {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  conversationId String?
  providerId    String?
  eventType     String   // e.g. authentication_error, stream_error, empty_response, tool_error
  message       String?
  details       String?
  createdAt     DateTime @default(now())

  @@index([createdAt])
  @@index([eventType])
  @@index([conversationId])
}

model HttpLog {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  method         String
  url            String
  statusCode     Int?
  clientIp       String?
  userAgent      String?
  userId         String?
  username       String?
  requestHeaders String?
  requestBody    String?
  responseBody   String?
  contentLength  Int?
  duration       Int?
  createdAt      DateTime @default(now())

  @@index([createdAt])
  @@index([method])
  @@index([statusCode])
}

model ToolLog {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  toolName       String
  handlerType    String   // "builtin" | "external"
  conversationId String?
  requestUrl     String?  // full URL (external tools)
  requestMethod  String?
  requestHeaders String?  // JSON (sanitized)
  requestBody    String?  // JSON (args sent to tool)
  responseStatus Int?    // HTTP status (external tools)
  responseBody   String?  // JSON (truncated)
  duration       Int?    // ms
  success        Boolean  @default(true)
  errorMessage   String?
  createdAt      DateTime @default(now())

  @@index([createdAt])
  @@index([toolName])
  @@index([conversationId])
}
