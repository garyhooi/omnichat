// =============================================================================
// OmniChat — Prisma Schema (MySQL variant)
// =============================================================================
// Activated by: scripts/use-provider.sh mysql
// Key differences from MongoDB variant:
//   - provider = "mysql"
//   - Uses @db.Text for long string fields
//   - Uses @default(cuid()) for IDs
//   - Standard relational indexes and foreign keys
//   - onDelete: Cascade for SQL relations
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Conversation {
  id        String   @id @default(cuid())
  visitorId String
  status    String   @default("active")
  agentId   String?
  metadata  String?  @db.Text
  visitorIp        String?
  visitorBrowser   String?
  visitorOs        String?
  visitorDevice    String?
  visitorCurrentUrl String?
  visitorTimezone   String?
  visitorLanguage   String?
  visitorScreenRes  String?
  visitorReferrer   String?
  rating           Int?
  review           String?
  agentRemarks     String?
  assignedUsername String?
  specialistUsername String?
  resolvedByUsername String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agent    AdminUser? @relation(fields: [agentId], references: [id])
  messages Message[]

  @@index([status])
  @@index([agentId])
  @@index([visitorId])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderType     String
  senderId       String?
  messageType    String   @default("text")
  content        String?  @db.Text
  attachmentUrl  String?
  attachmentThumbnailUrl String?
  readAt         DateTime?
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([createdAt])
}

model AdminUser {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  displayName  String
  role         String   @default("agent")
  isOnline     Boolean  @default(false)
  registrationIp String?
  lastLoginIp    String?
  userAgent      String?
  lastSeenAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  conversations Conversation[]
  sessions      Session[]
}

model Session {
  id          String   @id @default(cuid())
  jti         String   @unique
  adminUserId String
  expiresAt   DateTime
  revoked     Boolean  @default(false)
  createdAt   DateTime @default(now())

  admin       AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId])
}

model SiteConfig {
  id                 String   @id @default(cuid())
  siteName           String   @unique
  bubbleColor        String   @default("#4F46E5")
  welcomeMessage     String   @default("Hello! How can we help you today?") @db.Text
  offlineMessage     String   @default("We are currently offline. Please check back later.") @db.Text
  bubbleSize         String   @default("medium")
  bubblePattern      String   @default("solid")
  websitePosition    String   @default("bottom-right")
  bubbleIcon         String   @default("💬")
  allowedOrigins     String   @db.Text
  isActive           Boolean  @default(true)
  isOfflineMode      Boolean  @default(false)
  enableReadReceipts Boolean  @default(true)
  notificationSoundUrl String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model QuickReply {
  id        String   @id @default(cuid())
  title     String
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UploadToken {
  id             String   @id @default(cuid())
  token          String   @unique
  conversationId String
  expiresAt      DateTime
  used           Boolean  @default(false)
  createdAt      DateTime @default(now())

  @@index([conversationId])
  @@index([expiresAt])
}