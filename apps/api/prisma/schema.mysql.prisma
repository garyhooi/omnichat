// =============================================================================
// OmniChat — Prisma Schema (MySQL variant)
// =============================================================================
// Activated by: scripts/use-provider.sh mysql
// Key differences from MongoDB variant:
//   - provider = "mysql"
//   - Uses @db.Text for long string fields
//   - Uses @default(cuid()) for IDs
//   - Standard relational indexes and foreign keys
//   - onDelete: Cascade for SQL relations
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Conversation {
  id        String   @id @default(cuid())
  visitorId String
  status    String   @default("active")
  agentId   String?
  metadata  String?  @db.Text
  visitorIp        String?
  visitorBrowser   String?
  visitorOs        String?
  visitorDevice    String?
  visitorCurrentUrl String?
  visitorTimezone   String?
  visitorLanguage   String?
  visitorScreenRes  String?
  visitorReferrer   String?
  rating           Int?
  review           String?
  agentRemarks     String?
  assignedUsername String?
  specialistUsername String?
  resolvedByUsername String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agent    AdminUser? @relation(fields: [agentId], references: [id])
  messages Message[]

  @@index([status])
  @@index([agentId])
  @@index([visitorId])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderType     String
  senderId       String?
  messageType    String   @default("text")
  content        String?  @db.Text
  attachmentUrl  String?
  attachmentThumbnailUrl String?
  readAt         DateTime?
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([createdAt])
}

model AdminUser {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  displayName  String
  role         String   @default("agent")
  isOnline     Boolean  @default(false)
  isLocked     Boolean  @default(false)
  registrationIp String?
  lastLoginIp    String?
  userAgent      String?
  lastSeenAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  conversations Conversation[]
  sessions      Session[]
}

model Session {
  id          String   @id @default(cuid())
  jti         String   @unique
  adminUserId String
  expiresAt   DateTime
  revoked     Boolean  @default(false)
  createdAt   DateTime @default(now())

  admin       AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId])
}

model SiteConfig {
  id                 String   @id @default(cuid())
  siteName           String   @unique
  bubbleColor        String   @default("#4F46E5")
  welcomeMessage     String   @default("Hello! How can we help you today?") @db.Text
  offlineMessage     String   @default("We are currently offline. Please check back later.") @db.Text
  bubbleSize         String   @default("medium")
  bubblePattern      String   @default("solid")
  websitePosition    String   @default("bottom-right")
  bubbleIcon         String   @default("💬")
  allowedOrigins     String   @db.Text
  adminAllowedIps    String?  @db.Text
  isActive           Boolean  @default(true)
  isOfflineMode      Boolean  @default(false)
  enableReadReceipts Boolean  @default(true)
  notificationSoundUrl String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model QuickReply {
  id        String   @id @default(cuid())
  title     String
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UploadToken {
  id             String   @id @default(cuid())
  token          String   @unique
  conversationId String
  expiresAt      DateTime
  used           Boolean  @default(false)
  createdAt      DateTime @default(now())

  @@index([conversationId])
  @@index([expiresAt])
}

// =============================================================================
// AI Agent Models
// =============================================================================

model AiProvider {
  id             String   @id @default(cuid())
  name           String   @unique
  providerType   String   // openai, anthropic, openrouter, ollama, deepseek, gemini, grok
  apiKey         String?  @db.Text // encrypted; null for ollama
  baseUrl        String?  // custom endpoint (required for ollama/openrouter)
  chatModelId    String   // e.g. "gpt-4o", "claude-sonnet-4-20250514"
  embeddingModelId String? // e.g. "text-embedding-3-small"
  isActive       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model AiAgentConfig {
  id                     String   @id @default(cuid())
  enabled                Boolean  @default(false)
  systemPrompt           String   @default("You are a helpful customer support assistant. Be concise and helpful.") @db.Text
  greetingMessage        String?  @db.Text
  humanRequestKeywords   String?  @db.Text
  maxTokensPerResponse   Int      @default(1024)
  temperature            Float    @default(0.7)
  maxTurnsPerConversation Int     @default(50)
  maxTokensPerSession    Int      @default(50000)
  ragFailureThreshold    Int      @default(2)
  humanRequestThreshold  Int      @default(2)
  aiRateLimitPerMinute   Int      @default(10)
  spamIpBlacklistMinutes Int      @default(15)
  embeddingProviderId    String?  // ID of the provider to use for embeddings (null = use active chat provider)
  translateProviderId    String?  // ID of the provider to use for translation (null = use active chat provider)
  translationEnabled     Boolean  @default(true) // toggle translation feature on/off globally
  autoTranslationEnabled Boolean  @default(true) // auto-translate incoming messages
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model KnowledgeDocument {
  id              String   @id @default(cuid())
  title           String
  fileName        String
  fileType        String
  fileSize        Int
  content         String   @db.Text
  embeddingStatus String   @default("pending")
  errorMessage    String?  @db.Text
  chunkCount      Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  chunks DocumentChunk[]
}

/// For MySQL 9.0+: embeddings stored via native VECTOR type.
/// Embedding column managed via raw SQL (Prisma doesn't natively support MySQL VECTOR).
model DocumentChunk {
  id         String   @id @default(cuid())
  documentId String
  content    String   @db.Text
  /// Embedding stored as MySQL VECTOR(1536) — managed via raw SQL
  /// For MySQL < 9.0, embeddings are stored as JSON and searched in application code
  chunkIndex Int
  metadata   String?  @db.Text
  createdAt  DateTime @default(now())

  document KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
}

model AiConversationState {
  id                 String   @id @default(cuid())
  conversationId     String   @unique
  failureCount       Int      @default(0)
  ragFailureCount    Int      @default(0)
  humanRequestCount  Int      @default(0)
  tokensUsed         Int      @default(0)
  turnCount          Int      @default(0)
  handoffTriggered   Boolean  @default(false)
  handoffReason      String?
  isAiHandling       Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model ToolRegistration {
  id                 String   @id @default(cuid())
  name               String   @unique
  description        String   @db.Text
  parametersSchema   String   @db.Text
  handlerType        String   @default("builtin")
  endpoint           String?
  isActive           Boolean  @default(true)
  requiredPermission String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

// AI Logs (stores AI provider failures and important events)
model AiLog {
  id            String   @id @default(cuid())
  conversationId String?
  providerId    String?
  eventType     String   // e.g. authentication_error, stream_error, empty_response, tool_error
  message       String?  @db.Text
  details       String?  @db.Text
  createdAt     DateTime @default(now())
}

model HttpLog {
  id             String   @id @default(cuid())
  method         String
  url            String
  statusCode     Int?
  clientIp       String?
  userAgent      String?  @db.Text
  userId         String?
  username       String?
  requestHeaders String?  @db.Text
  requestBody    String?  @db.Text
  responseBody   String?  @db.Text
  contentLength  Int?
  duration       Int?
  createdAt      DateTime @default(now())

  @@index([createdAt])
  @@index([method])
  @@index([statusCode])
}
