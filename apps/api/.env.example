# =============================================================================
# OmniChat API — Environment Variables
# =============================================================================

# ---------------------------------------------------------------------------
# Database Configuration
# ---------------------------------------------------------------------------
# Options: mongodb, postgresql, mysql
DATABASE_PROVIDER=mongodb

# Connection String Examples:
# MongoDB: mongodb+srv://<username>:<password>@<cluster-url>/<dbname>?retryWrites=true&w=majority
# PostgreSQL: postgresql://<username>:<password>@<host>:<port>/<dbname>?schema=public
# MySQL: mysql://<username>:<password>@<host>:<port>/<dbname>
DATABASE_URL="mongodb+srv://<username>:<password>@<cluster-url>/<dbname>?retryWrites=true&w=majority"

# ---------------------------------------------------------------------------
# JWT Authentication
# ---------------------------------------------------------------------------
# Master signing key for all OmniChat-generated JWTs (admin/agent access tokens,
# refresh tokens, site tokens, and visitor tokens). Must be a strong random string
# in production. The main process will exit on startup if this matches the default.
JWT_SECRET=omnichat-local-dev-secret-change-in-production

# Default expiry used by JwtModule when no explicit expiresIn is provided.
# Individual token types override this: accessToken → ACCESS_TOKEN_EXPIRY,
# refreshToken → REFRESH_TOKEN_EXPIRY, visitorToken → hardcoded 30d.
JWT_EXPIRES_IN=24h

# Lifetime of the access token JWT returned by login/register/refresh.
# The access token is sent as Authorization: Bearer on every authenticated request.
# Short lifetime limits the window if stolen — pair with the refresh token.
ACCESS_TOKEN_EXPIRY=30m

# Lifetime of the opaque refresh token returned by login/register/refresh.
# The refresh token is stored in localStorage and exchanged for a new access token
# via POST /auth/refresh. Rotated on every use (old one is revoked).
REFRESH_TOKEN_EXPIRY=7d

# Pre-shared HS256 secret used to verify JWTs generated by an external/embedding
# site. The external site signs a JWT with this key and passes it via the
# data-external-token attribute on <omnichat-chat-widget> or <omnichat-chat-page>.
# OmniChat verifies the signature on POST /auth/visitor and uses the token for:
#   - Extracting operatorName for multi-tenant routing
#   - Extracting username for assigned visitor display name
#   - Forwarding it to external tool tokenUrl endpoints (AI tool token-exchange)
EXTERNAL_SITE_JWT_SECRET=change-me-to-a-random-64-char-string

# ---------------------------------------------------------------------------
# Server Configuration
# ---------------------------------------------------------------------------
PORT=3001

# ---------------------------------------------------------------------------
# Redis (Optional — falls back to in-memory if not set)
# ---------------------------------------------------------------------------
# Used for AI session state tracking, rate limiting, and multi-instance scaling.
# REDIS_URL=redis://localhost:6379

# ---------------------------------------------------------------------------
# AI Agent (Optional — AI features disabled if not configured in admin)
# ---------------------------------------------------------------------------
# AI provider configuration (API keys, models) is managed via the Admin UI
# and stored encrypted in the database. No env vars needed for AI providers.
# The following are system-level defaults that can be overridden in admin:
# AI_ENABLED=false

# ---------------------------------------------------------------------------
# Admin API Key (Required for admin-only endpoints)
# ---------------------------------------------------------------------------
# Used as an additional security layer for admin dashboard API calls.
# Passed via x-admin-api-key header.
ADMIN_API_KEY=omnichat-admin-key-change-in-production
