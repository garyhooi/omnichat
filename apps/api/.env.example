# =============================================================================
# OmniChat API — Environment Variables
# =============================================================================

# ---------------------------------------------------------------------------
# Database Configuration
# ---------------------------------------------------------------------------
# Options: mongodb, postgresql, mysql
DATABASE_PROVIDER=mongodb

# Connection String Examples:
# MongoDB: mongodb+srv://<username>:<password>@<cluster-url>/<dbname>?retryWrites=true&w=majority
# PostgreSQL: postgresql://<username>:<password>@<host>:<port>/<dbname>?schema=public
# MySQL: mysql://<username>:<password>@<host>:<port>/<dbname>
DATABASE_URL="mongodb+srv://<username>:<password>@<cluster-url>/<dbname>?retryWrites=true&w=majority"

# ---------------------------------------------------------------------------
# JWT Authentication
# ---------------------------------------------------------------------------
JWT_SECRET=omnichat-local-dev-secret-change-in-production

JWT_EXPIRES_IN=24h

# ---------------------------------------------------------------------------
# Server Configuration
# ---------------------------------------------------------------------------
PORT=3001

# ---------------------------------------------------------------------------
# Redis (Optional — falls back to in-memory if not set)
# ---------------------------------------------------------------------------
# Used for AI session state tracking, rate limiting, and multi-instance scaling.
# REDIS_URL=redis://localhost:6379

# ---------------------------------------------------------------------------
# AI Agent (Optional — AI features disabled if not configured in admin)
# ---------------------------------------------------------------------------
# AI provider configuration (API keys, models) is managed via the Admin UI
# and stored encrypted in the database. No env vars needed for AI providers.
# The following are system-level defaults that can be overridden in admin:
# AI_ENABLED=false

# ---------------------------------------------------------------------------
# Admin API Key (Required for admin-only endpoints)
# ---------------------------------------------------------------------------
# Used as an additional security layer for admin dashboard API calls.
# Passed via x-admin-api-key header.
ADMIN_API_KEY=omnichat-admin-key-change-in-production
