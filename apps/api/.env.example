# =============================================================================
# OmniChat API — Environment Variables
# =============================================================================

# ---------------------------------------------------------------------------
# Database Configuration
# ---------------------------------------------------------------------------
# Options: mongodb, postgresql, mysql
DATABASE_PROVIDER=mongodb

# Connection String Examples:
# MongoDB: mongodb+srv://<username>:<password>@<cluster-url>/<dbname>?retryWrites=true&w=majority
# PostgreSQL: postgresql://<username>:<password>@<host>:<port>/<dbname>?schema=public
# MySQL: mysql://<username>:<password>@<host>:<port>/<dbname>
DATABASE_URL="mongodb+srv://<username>:<password>@<cluster-url>/<dbname>?retryWrites=true&w=majority"

# ---------------------------------------------------------------------------
# JWT Authentication
# ---------------------------------------------------------------------------
JWT_SECRET=omnichat-local-dev-secret-change-in-production

JWT_EXPIRES_IN=24h

# ---------------------------------------------------------------------------
# Server Configuration
# ---------------------------------------------------------------------------
PORT=3001
