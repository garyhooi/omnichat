{
  "name": "@omnichat/web",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "OmniChat Vue 3 Web Components (Admin Portal & Visitor Widget)",
  "scripts": {
    "dev": "bun vite",
    "build:admin": "bun vite build --config vite.config.admin.ts",
    "build:client": "bun vite build --config vite.config.client.ts",
    "build": "bun run build:admin && bun run build:client",
    "preview": "bun vite preview"
  },
  "dependencies": {
    "socket.io-client": "^4.7.4",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "autoprefixer": "^10.4.17",
    "playwright": "^1.59.1",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.12",
    "vue-tsc": "^1.8.27"
  }
}
