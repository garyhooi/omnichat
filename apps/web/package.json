{
  "name": "@omnichat/web",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "OmniChat Vue 3 Web Components (Admin Portal, Chat Widget & Visitor Page)",
  "scripts": {
    "dev": "bun vite",
    "build:admin-portal": "bun vite build --config vite.config.admin-portal.ts",
    "build:chat-widget": "bun vite build --config vite.config.chat-widget.ts",
    "build:agent-widget": "bun vite build --config vite.config.agent-widget.ts",
    "build:chat-page": "bun vite build --config vite.config.chat-page.ts",
    "build": "bun run build:admin-portal && bun run build:chat-widget && bun run build:agent-widget && bun run build:chat-page",
    "preview": "bun vite preview"
  },
  "dependencies": {
    "@ai-sdk/vue": "^1.0.0",
    "dompurify": "^3.4.0",
    "marked": "^18.0.2",
    "pinia": "^2.2.0",
    "socket.io-client": "^4.7.4",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@types/dompurify": "^3.0.5",
    "@vitejs/plugin-vue": "^5.0.0",
    "autoprefixer": "^10.4.17",
    "playwright": "^1.59.1",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.12",
    "vue-tsc": "^1.8.27"
  }
}
