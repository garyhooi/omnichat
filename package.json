{
  "name": "omnichat",
  "version": "3.0.5",
  "private": true,
  "description": "High-performance self-hosted open-source live chat system",
  "workspaces": [
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "dev:api": "cd apps/api && bun run dev",
    "dev:web": "cd apps/web && bun run dev",
    "build:api": "cd apps/api && bun run build",
    "build:web": "cd apps/web && bun run build",
    "build:admin": "cd apps/web && bun run build:admin",
    "build:client": "cd apps/web && bun run build:client",
    "prisma:generate": "cd apps/api && bun run prisma:generate",
    "prisma:push": "cd apps/api && bun run prisma:push",
    "use-provider": "./scripts/use-provider.sh"
  },
  "dependencies": {
    "@types/cookie-parser": "^1.4.10",
    "cookie-parser": "^1.4.7"
  }
}
